# Supabase connection for the admin panel / backend.
# Copy this file to ".env.local" and paste your project's values.
# Find them in Supabase: Dashboard -> Project Settings -> API.
#
# Leave them EMPTY to run in local/offline mode (edits save in the browser only).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
